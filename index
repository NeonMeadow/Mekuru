var library={decks:[],activeDeckId:null,history:[]};
var session={order:[],pos:0,mode:"all",results:{},startTime:0,reviseIds:null};
var nextMode="focus"; /* mode selected in complete screen for next session */
var flipped=false;
var marking=false;
var currentScreen="study";
var stagedCards=[];

function activeDeck(){return library.decks.find(function(d){return d.id===library.activeDeckId;})||null;}
function nextDeckId(){return library.decks.reduce(function(m,d){return Math.max(m,d.id);},0)+1;}
function knownCountOf(deck){return Object.keys(deck.progress).filter(function(id){return deck.progress[id]==="known";}).length;}


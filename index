<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#F6F2EA">
<title>Washi</title>
<style>
  :root{
    --bg:#F6F2EA; --paper:#FFFDF8; --ink:#2A2722; --ink-soft:#8A8174;
    --line:#E2D9C7; --accent:#A6342B; --accent-soft:rgba(166,52,43,0.09);
    --known:#4F6B52; --known-soft:rgba(79,107,82,0.12);
    --shadow:0 1px 2px rgba(40,35,25,0.04), 0 8px 24px rgba(40,35,25,0.05);
    --radius:14px; --text-scale:1;
    --font-ui:-apple-system,BlinkMacSystemFont,"Hiragino Sans","Yu Gothic Medium","Segoe UI",Roboto,sans-serif;
    --font-display:-apple-system,BlinkMacSystemFont,"Hiragino Sans","Yu Gothic Medium","Segoe UI",Roboto,sans-serif;
    --font-back:"Iowan Old Style","Palatino Linotype",Palatino,Georgia,serif;
  }
  [data-theme="dark"]{
    --bg:#1E1B17; --paper:#272320; --ink:#ECE6DA; --ink-soft:#9C9284;
    --line:#3D3731; --accent:#E0857B; --accent-soft:rgba(224,133,123,0.14);
    --known:#8FB28F; --known-soft:rgba(143,178,143,0.14); --shadow:none;
  }
  *{box-sizing:border-box;} html,body{margin:0;padding:0;}
  [hidden]{display:none !important;}
  body{
    background:var(--bg); color:var(--ink); font-family:var(--font-ui);
    min-height:100vh; min-height:100dvh;
    display:flex; justify-content:center; align-items:center;
    padding:max(20px,env(safe-area-inset-top)) max(16px,env(safe-area-inset-right)) max(20px,env(safe-area-inset-bottom)) max(16px,env(safe-area-inset-left));
    transition:background-color .2s ease, color .2s ease;
  }
  #app{ width:100%; max-width:440px; display:flex; flex-direction:column; padding:18px 20px 28px; }
  button{font-family:inherit;cursor:pointer;}
  input,textarea,select{font-family:inherit;}
  button:focus-visible,input:focus-visible,textarea:focus-visible,[tabindex]:focus-visible{outline:2px solid var(--accent);outline-offset:2px;}

  /* ---- header ---- */
  header{display:flex;align-items:center;justify-content:space-between;gap:10px;padding-bottom:14px;border-bottom:1px solid var(--line);margin-bottom:18px;}
  #headerLabel{font-size:18px;font-weight:600;color:var(--ink);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;min-width:0;}
  .headerIcons{display:flex;gap:8px;flex-shrink:0;}
  .iconCircleBtn{background:none;border:1px solid var(--line);color:var(--ink-soft);border-radius:999px;width:34px;height:34px;font-size:15px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
  .iconCircleBtn:hover{border-color:var(--ink-soft);color:var(--ink);}
  .iconCircleBtn.active{background:var(--ink);color:var(--paper);border-color:var(--ink);}
  .deckPill{display:flex;align-items:center;gap:4px;background:none;border:none;color:var(--ink-soft);font-size:12.5px;padding:0;margin:-6px 0 16px;cursor:pointer;}
  .deckPill:hover{color:var(--ink);}
  .deckPill .chev{font-size:12px;opacity:.7;}

  /* ---- screens / subviews ---- */
  .screen{display:none;flex-direction:column;} .screen.active{display:flex;}
  .subview{display:none;} .subview.active{display:flex;flex-direction:column;}
  #emptyView.active{align-items:center;text-align:center;gap:18px;padding:56px 0;}
  #emptyView h1{font-size:20px;margin:0;font-weight:600;}
  #emptyView p{font-size:14px;color:var(--ink-soft);margin:0;max-width:300px;line-height:1.5;}

  /* ---- live progress bar (tri-color) ---- */
  .progressRow{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;font-size:12.5px;color:var(--ink-soft);gap:8px;}
  .progressScores{display:flex;gap:8px;flex-shrink:0;}
  .scoreKnown{color:var(--known);font-weight:600;}
  .scoreUnknown{color:var(--accent);font-weight:600;}
  .progressBar{flex:1;height:8px;background:var(--line);border-radius:4px;overflow:hidden;position:relative;}
  #progressKnown{position:absolute;left:0;top:0;height:100%;background:var(--known);transition:width .25s ease;}
  #progressUnknown{position:absolute;top:0;height:100%;background:var(--accent);transition:left .25s ease,width .25s ease;}
  .progressRight{flex-shrink:0;white-space:nowrap;}

  /* ---- mode buttons ---- */
  .modeRow{display:flex;gap:6px;margin-bottom:18px;}
  .modeBtn{flex:1;border:1px solid var(--line);background:var(--paper);color:var(--ink-soft);border-radius:999px;padding:7px 6px;font-size:12px;font-weight:500;}
  .modeBtn.active{background:var(--ink);color:var(--paper);border-color:var(--ink);}

  /* ---- card ---- */
  .cardStage{display:flex;align-items:center;justify-content:center;margin:6px 0;perspective:1200px;}
  .card{position:relative;width:100%;max-width:340px;height:clamp(220px,52vh,300px);cursor:pointer;}
  .cardInner{position:relative;width:100%;height:100%;transition:transform .35s cubic-bezier(.2,.8,.2,1);transform-style:preserve-3d;}
  .card.flipped .cardInner{transform:rotateY(180deg);}
  .face{position:absolute;inset:0;background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);display:flex;align-items:center;justify-content:center;padding:24px;backface-visibility:hidden;-webkit-backface-visibility:hidden;text-align:center;}
  .face-back{transform:rotateY(180deg);}
  .face-front .text{font-family:var(--font-display);font-size:calc(clamp(40px,12vw,64px)*var(--text-scale));font-weight:600;line-height:1.2;word-break:break-word;}
  .face-back .text{font-family:var(--font-back);font-style:italic;font-size:calc(clamp(20px,6vw,28px)*var(--text-scale));line-height:1.4;color:var(--ink);}
  .tapHint{position:absolute;bottom:14px;left:0;right:0;text-align:center;font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-soft);opacity:.7;}

  /* ---- hanko stamp ---- */
  .stamp{position:absolute;top:50%;left:50%;width:128px;height:128px;margin:-64px 0 0 -64px;display:flex;align-items:center;justify-content:center;opacity:0;background:var(--paper);transform:scale(.45) rotate(var(--stamp-rot,-8deg));transition:opacity .2s ease,transform .3s cubic-bezier(.34,1.56,.64,1);pointer-events:none;}
  .stamp.show{opacity:1;transform:scale(1) rotate(var(--stamp-rot,-8deg));}
  .stamp.know{--stamp-rot:-8deg;border-radius:50%;border:3px solid var(--known);box-shadow:0 0 0 3px var(--paper),0 0 0 6px var(--known);color:var(--known);}
  .stamp.dontknow{--stamp-rot:7deg;border-radius:10px;border:3px solid var(--accent);color:var(--accent);}
  .stampText{font-family:var(--font-display);font-weight:700;font-size:27px;letter-spacing:.05em;line-height:1.15;text-align:center;}

  /* ---- action buttons ---- */
  .actionRow{display:flex;gap:10px;margin-top:18px;min-height:48px;}
  .actionBtn{flex:1;border-radius:12px;border:1px solid var(--line);background:var(--paper);padding:13px 10px;font-size:14.5px;font-weight:600;display:flex;align-items:center;justify-content:center;gap:6px;}
  .actionBtn.dontknow{color:var(--accent);border-color:rgba(166,52,43,0.3);}
  .actionBtn.dontknow:hover{background:var(--accent-soft);}
  .actionBtn.know{background:var(--known-soft);border-color:transparent;color:var(--known);}
  .actionBtn.know:hover{background:var(--known);color:#fff;}
  .hintRow{text-align:center;font-size:11.5px;color:var(--ink-soft);margin-top:10px;opacity:.8;}
  .skipLink{background:none;border:none;color:var(--ink-soft);font-size:12.5px;text-decoration:underline;text-underline-offset:2px;align-self:center;margin-top:2px;}

  /* ---- session complete ---- */
  #completeView.active{gap:16px;padding:20px 0;}
  #completeView h2{margin:0;font-size:19px;font-weight:600;}
  .sessionSummaryCard{background:var(--paper);border:1px solid var(--line);border-radius:12px;padding:16px;}
  .sessionNums{display:flex;gap:0;margin-bottom:12px;}
  .sessionNum{flex:1;text-align:center;}
  .sessionNum .n{font-size:28px;font-weight:700;line-height:1;}
  .sessionNum .n.green{color:var(--known);}
  .sessionNum .n.red{color:var(--accent);}
  .sessionNum .l{font-size:11px;color:var(--ink-soft);margin-top:3px;text-transform:uppercase;letter-spacing:.05em;}
  .sessionDivider{width:1px;background:var(--line);margin:4px 16px;}
  .sessionBarWrap{height:10px;background:var(--line);border-radius:5px;overflow:hidden;display:flex;}
  .sessionBarKnown{height:100%;background:var(--known);}
  .sessionBarUnknown{height:100%;background:var(--accent);}
  .nextLabel{font-size:11px;text-transform:uppercase;letter-spacing:.07em;color:var(--ink-soft);margin-bottom:6px;font-weight:600;}
  .primaryBtn{background:var(--ink);color:var(--paper);border:none;border-radius:12px;padding:13px 22px;font-size:14.5px;font-weight:600;text-align:center;}
  .outlineBtn{background:none;border:1px solid var(--line);color:var(--ink);border-radius:12px;padding:13px 22px;font-size:14.5px;font-weight:600;text-align:center;}
  .outlineBtn:hover{border-color:var(--ink-soft);}
  .btnStack{display:flex;flex-direction:column;gap:8px;}

  /* ---- settings screen ---- */
  .settingsTopRow{display:flex;align-items:center;gap:8px;margin-bottom:20px;}
  .backLink{background:none;border:none;color:var(--ink-soft);font-size:14px;padding:4px 0;display:flex;align-items:center;gap:4px;}
  .backLink:hover{color:var(--ink);}
  .panelSection{margin-bottom:28px;}
  .panelSection h3{font-size:12px;text-transform:uppercase;letter-spacing:.07em;color:var(--ink-soft);margin:0 0 10px;font-weight:600;}
  .deckList{display:flex;flex-direction:column;gap:6px;}
  .deckRow{display:flex;align-items:center;justify-content:space-between;gap:8px;padding:11px 13px;border:1px solid var(--line);border-radius:10px;background:var(--paper);font-size:14px;cursor:pointer;}
  .deckRow.active{border-color:var(--accent);}
  .deckRow .name{flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
  .deckRow .count{color:var(--ink-soft);font-size:12px;flex-shrink:0;}
  .emptyHint{font-size:13px;color:var(--ink-soft);}
  textarea.csvPaste{width:100%;min-height:90px;border:1px solid var(--line);border-radius:10px;padding:9px 10px;font-size:12.5px;font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;resize:vertical;background:var(--paper);color:var(--ink);}
  .fieldLabel{font-size:12px;color:var(--ink-soft);margin:10px 0 5px;}
  .textInput{width:100%;border:1px solid var(--line);border-radius:10px;padding:9px 10px;font-size:13.5px;background:var(--paper);color:var(--ink);}
  .fileBtn{display:inline-block;border:1px solid var(--line);border-radius:10px;padding:9px 12px;font-size:13px;background:var(--paper);color:var(--ink);}
  .btnRow{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;}
  .smallBtn{border:1px solid var(--line);background:var(--paper);border-radius:9px;padding:8px 12px;font-size:12.5px;font-weight:500;color:var(--ink);text-align:left;}
  .smallBtn.primary{background:var(--ink);color:var(--paper);border-color:var(--ink);}
  .smallBtn.danger{color:var(--accent);}
  .smallBtn.danger.confirming{background:var(--accent);color:#fff;border-color:var(--accent);}
  .smallBtn:disabled{opacity:.4;cursor:default;}
  .muted{color:var(--ink-soft);font-size:12px;line-height:1.5;}
  .previewBox{margin-top:12px;border:1px solid var(--line);border-radius:10px;padding:12px 13px;background:var(--accent-soft);}
  .previewBox.error{background:transparent;border-color:var(--accent);}
  .previewCount{font-size:13.5px;font-weight:600;margin-bottom:6px;}
  .previewRows{font-size:12px;color:var(--ink-soft);line-height:1.6;font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;white-space:pre-line;}
  .previewMore{font-size:11.5px;color:var(--ink-soft);margin-top:4px;}
  .destinationBlock{margin-top:16px;display:flex;flex-direction:column;gap:10px;}
  .destinationBlock.disabled{opacity:.45;pointer-events:none;}
  .saveNote{font-size:11px;color:var(--ink-soft);text-align:center;margin-top:14px;opacity:.85;min-height:14px;}
  .fontSizeRow{display:flex;align-items:center;gap:14px;}
  .stepBtn{border:1px solid var(--line);background:var(--paper);color:var(--ink);border-radius:9px;padding:8px 16px;font-size:14px;font-weight:700;}
  .stepBtn:disabled{opacity:.35;cursor:default;}
  #fontSizeLabel{font-size:13.5px;color:var(--ink-soft);min-width:42px;text-align:center;}

  /* ---- history screen ---- */
  .histStats{display:flex;gap:20px;margin-bottom:20px;}
  .histStat{flex:1;}
  .histStatN{font-size:22px;font-weight:700;color:var(--ink);}
  .histStatL{font-size:11px;color:var(--ink-soft);text-transform:uppercase;letter-spacing:.05em;margin-top:1px;}
  .bestSessionCard{background:var(--paper);border:1px solid var(--line);border-radius:12px;padding:14px;margin-bottom:20px;}
  .bestLabel{font-size:11px;text-transform:uppercase;letter-spacing:.07em;color:var(--ink-soft);font-weight:600;margin-bottom:8px;}
  .bestRow{display:flex;align-items:center;gap:12px;}
  .bestPct{font-size:28px;font-weight:700;}
  .bestMeta{font-size:12px;color:var(--ink-soft);}
  .bestBar{height:8px;background:var(--line);border-radius:4px;overflow:hidden;display:flex;margin-top:10px;}
  .bestBarKnown{height:100%;background:var(--known);}
  .bestBarUnknown{height:100%;background:var(--accent);}
  .bubblesSection{margin-bottom:20px;}
  .bubblesLabel{font-size:11px;text-transform:uppercase;letter-spacing:.07em;color:var(--ink-soft);font-weight:600;margin-bottom:10px;}
  .bubblesWrap{display:flex;flex-wrap:wrap;gap:8px;align-items:flex-end;}
  .bubble{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10.5px;font-weight:700;color:#fff;flex-shrink:0;position:relative;cursor:default;}
  .bubble.best{outline:2.5px solid var(--ink);outline-offset:2px;}
  .histList{display:flex;flex-direction:column;}
  .histEntry{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--line);}
  .histEntry:last-child{border-bottom:none;}
  .histPctBadge{width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0;}
  .histMeta{flex:1;min-width:0;}
  .histDate{font-size:12.5px;color:var(--ink);}
  .histSub{font-size:11px;color:var(--ink-soft);margin-top:2px;}
  .histBar{height:5px;background:var(--line);border-radius:3px;overflow:hidden;display:flex;margin-top:5px;}
  .histBarKnown{height:100%;background:var(--known);}
  .histBarUnknown{height:100%;background:var(--accent);}
  .noHistHint{font-size:13px;color:var(--ink-soft);padding:20px 0;}

  @media (prefers-reduced-motion: reduce){
    .cardInner,.stamp,.progressBar,body{transition:none !important;}
    #progressKnown,#progressUnknown{transition:none !important;}
  }
</style>
</head>
<body>
<div id="app">

  <header>
    <span id="headerLabel">Washi</span>
    <div class="headerIcons">
      <button class="iconCircleBtn" id="historyToggle" aria-label="Session history" title="Session history">◷</button>
      <button class="iconCircleBtn" id="themeToggle" aria-label="Toggle dark mode" title="Toggle dark mode">☾</button>
      <button class="iconCircleBtn" id="settingsToggle" aria-label="Settings" title="Settings">⚙</button>
    </div>
  </header>

  <button class="deckPill" id="deckPill" hidden>
    <span id="deckPillName"></span><span class="chev">›</span>
  </button>

  <!-- ========== STUDY SCREEN ========== -->
  <div class="screen active" id="studyScreen">

    <div class="subview" id="emptyView">
      <h1>No deck yet</h1>
      <p>Import a two-column CSV — one side per column — to start studying.</p>
      <button class="smallBtn primary" id="emptyImportBtn">Import a CSV</button>
    </div>

    <div class="subview" id="liveView">
      <div class="progressRow">
        <div class="progressScores">
          <span class="scoreKnown" id="scoreKnown">✓ 0</span>
          <span class="scoreUnknown" id="scoreUnknown">✗ 0</span>
        </div>
        <div class="progressBar">
          <div id="progressKnown" style="width:0%"></div>
          <div id="progressUnknown" style="width:0%;left:0%"></div>
        </div>
        <span class="progressRight" id="progressRight">0 / 0</span>
      </div>

      <div class="modeRow">
        <button class="modeBtn active" id="modeAll" title="Study every card in the deck">All</button>
        <button class="modeBtn" id="modeFocus" title="Only cards you haven't mastered">Focus</button>
        <button class="modeBtn" id="modeMixed" title="Mostly unknown + some known to keep them fresh">Mixed</button>
      </div>

      <div class="cardStage">
        <div class="card" id="card" tabindex="0" role="button" aria-label="Flashcard — tap or press Space to flip">
          <div class="cardInner">
            <div class="face face-front">
              <span class="text" id="frontText"></span>
              <span class="tapHint">tap to reveal</span>
            </div>
            <div class="face face-back">
              <span class="text" id="backText"></span>
              <div class="stamp" id="stamp"><span class="stampText" id="stampText"></span></div>
            </div>
          </div>
        </div>
      </div>

      <div class="actionRow">
        <button class="actionBtn dontknow" id="btnDontKnow">✗ Don't know</button>
        <button class="actionBtn know" id="btnKnow">Got it ✓</button>
      </div>
      <button class="skipLink" id="skipBtn">skip without marking</button>
      <p class="hintRow">space / tap to flip · ← don't know · → got it</p>
    </div>

    <div class="subview" id="completeView">
      <h2 id="completeTitle">Session complete</h2>
      <div class="sessionSummaryCard">
        <div class="sessionNums">
          <div class="sessionNum"><div class="n green" id="completeKnown">0</div><div class="l">Got it</div></div>
          <div class="sessionDivider"></div>
          <div class="sessionNum"><div class="n red" id="completeUnknown">0</div><div class="l">Don't know</div></div>
          <div class="sessionDivider"></div>
          <div class="sessionNum"><div class="n" id="completePct">—</div><div class="l">Score</div></div>
        </div>
        <div class="sessionBarWrap">
          <div class="sessionBarKnown" id="sessionBarKnown"></div>
          <div class="sessionBarUnknown" id="sessionBarUnknown"></div>
        </div>
      </div>
      <div class="btnStack">
        <button class="primaryBtn" id="reviseBtn" hidden>Revise mistakes →</button>
        <div>
          <div class="nextLabel">Next session</div>
          <div class="modeRow" style="margin-bottom:10px;">
            <button class="modeBtn" id="nextAll" title="Study every card">All</button>
            <button class="modeBtn active" id="nextFocus" title="Unknown cards only">Focus</button>
            <button class="modeBtn" id="nextMixed" title="Mostly unknown + some known">Mixed</button>
          </div>
          <button class="outlineBtn" id="studyAgainBtn" style="width:100%">Study again</button>
        </div>
      </div>
    </div>

  </div>

  <!-- ========== SETTINGS SCREEN ========== -->
  <div class="screen" id="settingsScreen">
    <div class="settingsTopRow">
      <button class="backLink" id="backBtn">‹ Back to cards</button>
    </div>
    <div class="panelSection">
      <h3>Your decks</h3>
      <div class="deckList" id="deckList"></div>
      <p class="emptyHint" id="noDeckHint" hidden>No decks yet — import one below.</p>
    </div>
    <div class="panelSection">
      <h3>Card text size</h3>
      <div class="fontSizeRow">
        <button class="stepBtn" id="fontDecBtn" aria-label="Decrease text size">A−</button>
        <span id="fontSizeLabel">100%</span>
        <button class="stepBtn" id="fontIncBtn" aria-label="Increase text size">A+</button>
      </div>
    </div>
    <div class="panelSection">
      <h3>Import cards</h3>
      <p class="muted">Choose a CSV file or paste its contents below. Two columns per line: one side of the card, then the other.</p>
      <input type="file" id="csvFileInput" accept=".csv,text/csv" style="display:none;">
      <label class="fileBtn" for="csvFileInput">Choose CSV file</label>
      <div class="fieldLabel">or paste CSV text</div>
      <textarea class="csvPaste" id="stagingArea" placeholder="front,back&#10;あ,a&#10;い,i&#10;う,u"></textarea>
      <div id="previewBox" class="previewBox" hidden>
        <div class="previewCount" id="previewCount"></div>
        <div class="previewRows" id="previewRows"></div>
        <div class="previewMore" id="previewMore"></div>
      </div>
      <div class="destinationBlock disabled" id="destinationBlock">
        <div>
          <div class="fieldLabel" style="margin-top:0;">Save as a new deck</div>
          <input class="textInput" id="newDeckName" placeholder="Deck name">
          <div class="btnRow">
            <button class="smallBtn primary" id="createDeckBtn">Create new deck</button>
          </div>
        </div>
        <div id="updateExistingBlock" hidden>
          <div class="fieldLabel">— or add to your current deck —</div>
          <div class="btnRow">
            <button class="smallBtn" id="appendBtn">Add new cards</button>
            <button class="smallBtn" id="replaceBtn">Replace deck</button>
          </div>
          <p class="muted" id="updateDetail" style="margin-top:8px;"></p>
        </div>
      </div>
    </div>
    <div class="panelSection" id="thisDeckSection" hidden>
      <h3>This deck</h3>
      <div class="btnRow">
        <button class="smallBtn" id="resetProgressBtn">Reset progress</button>
        <button class="smallBtn danger" id="deleteDeckBtn">Delete deck</button>
        <button class="smallBtn danger" id="clearHistoryBtn">Clear history</button>
      </div>
    </div>
    <p class="saveNote" id="saveNote"></p>
  </div>

  <!-- ========== HISTORY SCREEN ========== -->
  <div class="screen" id="historyScreen">
    <div class="settingsTopRow">
      <button class="backLink" id="histBackBtn">‹ Back to cards</button>
    </div>
    <div id="historyContent"></div>
  </div>

</div>

<script>
(function(){
"use strict";

/* ================= storage ================= */
var hasClaudeStorage = (typeof window.storage !== "undefined" && window.storage && typeof window.storage.get === "function");
var LIB_KEY = "flashcards:library";
var THEME_KEY = "flashcards:theme";
var FONT_KEY = "flashcards:textScale";

function storageGet(key){
  if(hasClaudeStorage) return window.storage.get(key,false).then(function(r){return r?JSON.parse(r.value):null;}).catch(function(){return null;});
  try{var v=localStorage.getItem(key);return Promise.resolve(v?JSON.parse(v):null);}catch(e){return Promise.resolve(null);}
}
function storageSet(key,value){
  if(hasClaudeStorage) return window.storage.set(key,JSON.stringify(value),false).then(function(){return true;}).catch(function(){return false;});
  try{localStorage.setItem(key,JSON.stringify(value));return Promise.resolve(true);}catch(e){return Promise.resolve(false);}
}

var saveTimer=null;
function scheduleSave(){
  clearTimeout(saveTimer);
  el("saveNote").textContent="Saving…";
  saveTimer=setTimeout(function(){
    storageSet(LIB_KEY,library).then(function(ok){el("saveNote").textContent=ok?"":"Couldn't save — progress may reset on reload.";});
  },250);
}

/* ================= helpers ================= */
function el(id){return document.getElementById(id);}
function escapeHtml(s){var d=document.createElement("div");d.textContent=s;return d.innerHTML;}
function shuffle(arr){
  var a=arr.slice();
  for(var i=a.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=a[i];a[i]=a[j];a[j]=t;}
  return a;
}
function pctColor(pct){
  var h=Math.round(pct*1.2);
  return "hsl("+h+",65%,46%)";
}
function fmtDate(ts){
  var d=new Date(ts);
  return d.toLocaleDateString(undefined,{month:"short",day:"numeric"})+" "+d.toLocaleTimeString(undefined,{hour:"2-digit",minute:"2-digit"});
}

/* ================= CSV parsing ================= */
function parseCSV(text){
  var rows=[],i=0,field="",row=[],inQuotes=false;
  function pushField(){row.push(field);field="";}
  function pushRow(){pushField();rows.push(row);row=[];}
  while(i<text.length){
    var c=text[i];
    if(inQuotes){
      if(c==='"'){if(text[i+1]==='"'){field+='"';i+=2;continue;}inQuotes=false;i++;continue;}
      else{field+=c;i++;continue;}
    } else {
      if(c==='"'){inQuotes=true;i++;continue;}
      if(c===','){pushField();i++;continue;}
      if(c==='\r'){i++;continue;}
      if(c==='\n'){pushRow();i++;continue;}
      field+=c;i++;continue;
    }
  }
  if(field.length>0||row.length>0)pushRow();
  return rows.map(function(r){return r.map(function(c){return c.trim();});}).filter(function(r){return r.length>=2&&(r[0]!=""||r[1]!="");});
}
var HEADER_PAIRS=["front,back","term,definition","question,answer","kana,romaji","kana,meaning","character,reading","japanese,english","word,translation"];
function rowsToCards(rows){
  var data=rows;
  if(data.length>0){var hk=data[0].slice(0,2).map(function(s){return s.toLowerCase();}).join(",");if(HEADER_PAIRS.indexOf(hk)!==-1)data=data.slice(1);}
  return data.map(function(r){return{front:r[0],back:r[1]};});
}
function cardKey(c){return c.front+"\u0000"+c.back;}
function mergeCards(existingCards,existingProgress,newCards,mode){
  var existingByKey={};existingCards.forEach(function(c){existingByKey[cardKey(c)]=c;});
  var nextId=existingCards.reduce(function(m,c){return Math.max(m,c.id);},0)+1;
  if(mode==="replace"){
    var cards=newCards.map(function(c){var ex=existingByKey[cardKey(c)];return ex?ex:{id:nextId++,front:c.front,back:c.back};});
    var keepIds={};cards.forEach(function(c){keepIds[c.id]=true;});
    var progress={};Object.keys(existingProgress).forEach(function(id){if(keepIds[id])progress[id]=existingProgress[id];});
    return{cards:cards,progress:progress};
  } else {
    var cards2=existingCards.slice();
    newCards.forEach(function(c){if(!existingByKey[cardKey(c)]){var card={id:nextId++,front:c.front,back:c.back};cards2.push(card);existingByKey[cardKey(c)]=card;}});
    return{cards:cards2,progress:Object.assign({},existingProgress)};
  }
}


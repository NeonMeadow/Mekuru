/* staging / import */
var stagingArea=el("stagingArea"),previewBox=el("previewBox"),previewCount=el("previewCount");
var previewRows=el("previewRows"),previewMore=el("previewMore"),destinationBlock=el("destinationBlock");
var newDeckNameInput=el("newDeckName"),updateExistingBlock=el("updateExistingBlock"),updateDetail=el("updateDetail");
var createDeckBtn=el("createDeckBtn"),appendBtn=el("appendBtn"),replaceBtn=el("replaceBtn");

function readFileAsText(file){
  return new Promise(function(resolve,reject){var r=new FileReader();r.onload=function(){resolve(r.result);};r.onerror=reject;r.readAsText(file);});
}
el("csvFileInput").addEventListener("change",function(e){
  var file=e.target.files[0];if(!file)return;
  if(!newDeckNameInput.value.trim())newDeckNameInput.value=file.name.replace(/\.csv$/i,"");
  readFileAsText(file).then(function(text){stagingArea.value=text;updatePreview();});
  e.target.value="";
});
stagingArea.addEventListener("input",updatePreview);

function updatePreview(){
  var text=stagingArea.value;
  if(!text.trim()){previewBox.hidden=true;stagedCards=[];renderDestinationBlock();return;}
  var rows=parseCSV(text),cards=rowsToCards(rows);stagedCards=cards;previewBox.hidden=false;
  if(cards.length===0){
    previewBox.classList.add("error");previewCount.textContent="No valid rows found";
    previewRows.textContent="Make sure each line has two values separated by a comma.";previewMore.textContent="";
  } else {
    previewBox.classList.remove("error");previewCount.textContent=cards.length+(cards.length===1?" card found":" cards found");
    previewRows.textContent=cards.slice(0,5).map(function(c){return c.front+" → "+c.back;}).join("\n");
    previewMore.textContent=cards.length>5?"…and "+(cards.length-5)+" more":"";
  }
  renderDestinationBlock();
}
function renderDestinationBlock(){
  var hasCards=stagedCards.length>0;
  destinationBlock.classList.toggle("disabled",!hasCards);createDeckBtn.disabled=!hasCards;
  createDeckBtn.textContent=hasCards?("Create new deck — "+stagedCards.length+" card"+(stagedCards.length===1?"":"s")):"Create new deck";
  var deck=activeDeck();updateExistingBlock.hidden=!deck;
  if(deck&&hasCards){
    var existingByKey={};deck.cards.forEach(function(c){existingByKey[cardKey(c)]=true;});
    var newOnes=stagedCards.filter(function(c){return!existingByKey[cardKey(c)];}).length;
    var dupes=stagedCards.length-newOnes;
    var matching=stagedCards.filter(function(c){return existingByKey[cardKey(c)];}).length;
    var removed=deck.cards.length-matching;
    appendBtn.disabled=false;replaceBtn.disabled=false;
    appendBtn.textContent="Add "+newOnes+" new card"+(newOnes===1?"":"s");
    replaceBtn.textContent="Replace deck ("+stagedCards.length+" total)";
    updateDetail.textContent="Adding: skips "+dupes+" already in \u201c"+deck.name+"\u201d. Replacing: keeps progress for "+matching+" matching card"+(matching===1?"":"s")+", removes "+removed+" no longer in the file.";
  } else if(deck){
    appendBtn.disabled=true;replaceBtn.disabled=true;appendBtn.textContent="Add new cards";replaceBtn.textContent="Replace deck";updateDetail.textContent="";
  }
}
function resetStaging(){stagingArea.value="";stagedCards=[];previewBox.hidden=true;newDeckNameInput.value="";renderDestinationBlock();}

createDeckBtn.addEventListener("click",function(){
  if(stagedCards.length===0)return;
  var id=nextDeckId(),cards=stagedCards.map(function(c,i){return{id:i+1,front:c.front,back:c.back};});
  var name=newDeckNameInput.value.trim()||("Deck "+id);
  library.decks.push({id:id,name:name,cards:cards,progress:{}});library.activeDeckId=id;
  scheduleSave();resetStaging();renderStudy();showScreen("study");
});
appendBtn.addEventListener("click",function(){
  var deck=activeDeck();if(!deck||stagedCards.length===0)return;
  var result=mergeCards(deck.cards,deck.progress,stagedCards,"append");
  deck.cards=result.cards;deck.progress=result.progress;scheduleSave();resetStaging();renderSettings();renderProgress();
});
replaceBtn.addEventListener("click",function(){
  var deck=activeDeck();if(!deck||stagedCards.length===0)return;
  var result=mergeCards(deck.cards,deck.progress,stagedCards,"replace");
  deck.cards=result.cards;deck.progress=result.progress;scheduleSave();resetStaging();renderSettings();renderProgress();
});

function twoStepConfirm(btn,onConfirm){
  var confirming=false,timer=null,original=btn.textContent;
  btn.addEventListener("click",function(){
    if(!confirming){confirming=true;btn.textContent="Click again to confirm";btn.classList.add("confirming");timer=setTimeout(function(){confirming=false;btn.textContent=original;btn.classList.remove("confirming");},3000);}
    else{clearTimeout(timer);confirming=false;btn.textContent=original;btn.classList.remove("confirming");onConfirm();}
  });
}
twoStepConfirm(el("resetProgressBtn"),function(){var deck=activeDeck();if(!deck)return;deck.progress={};scheduleSave();renderSettings();});
twoStepConfirm(el("deleteDeckBtn"),function(){
  var deck=activeDeck();if(!deck)return;
  library.decks=library.decks.filter(function(d){return d.id!==deck.id;});
  library.activeDeckId=library.decks.length?library.decks[0].id:null;
  scheduleSave();renderSettings();renderStudy();
});
twoStepConfirm(el("clearHistoryBtn"),function(){
  var deck=activeDeck();if(!deck)return;
  library.history=(library.history||[]).filter(function(h){return h.deckId!==deck.id;});
  scheduleSave();renderSettings();
});

/* ================= boot ================= */
Promise.all([storageGet(LIB_KEY),storageGet(THEME_KEY),storageGet(FONT_KEY)]).then(function(results){
  var data=results[0],theme=results[1],savedScale=results[2];
  if(data&&data.decks&&data.decks.length){
    library=data;
    if(!library.history)library.history=[];
    if(!library.decks.some(function(d){return d.id===library.activeDeckId;}))library.activeDeckId=library.decks[0].id;
  }
  applyTheme(theme==="dark"?"dark":"light");
  applyTextScale(typeof savedScale==="number"?savedScale:1);
  renderStudy();
});

})();
</script>
</body>
</html>

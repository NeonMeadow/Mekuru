/* ================= theme + font ================= */
var themeToggle=el("themeToggle");
function applyTheme(theme){
  if(theme==="dark")document.documentElement.setAttribute("data-theme","dark");
  else document.documentElement.removeAttribute("data-theme");
  themeToggle.textContent=theme==="dark"?"☀":"☾";
}
themeToggle.addEventListener("click",function(){
  var isDark=document.documentElement.getAttribute("data-theme")==="dark";
  var next=isDark?"light":"dark";
  applyTheme(next);storageSet(THEME_KEY,next);
});

var FONT_MIN=0.7,FONT_MAX=1.6,FONT_STEP=0.1,textScale=1;
var fontDecBtn=el("fontDecBtn"),fontIncBtn=el("fontIncBtn"),fontSizeLabel=el("fontSizeLabel");
function applyTextScale(v){
  textScale=Math.round(v*100)/100;
  document.documentElement.style.setProperty("--text-scale",textScale);
  fontSizeLabel.textContent=Math.round(textScale*100)+"%";
  fontDecBtn.disabled=textScale<=FONT_MIN+1e-9;
  fontIncBtn.disabled=textScale>=FONT_MAX-1e-9;
}
fontDecBtn.addEventListener("click",function(){applyTextScale(Math.max(FONT_MIN,textScale-FONT_STEP));storageSet(FONT_KEY,textScale);});
fontIncBtn.addEventListener("click",function(){applyTextScale(Math.min(FONT_MAX,textScale+FONT_STEP));storageSet(FONT_KEY,textScale);});

/* ================= session ================= */
var emptyView=el("emptyView"),liveView=el("liveView"),completeView=el("completeView");
var cardEl=el("card"),stampEl=el("stamp"),stampTextEl=el("stampText");
var frontText=el("frontText"),backText=el("backText");

function showSubview(which){
  emptyView.classList.toggle("active",which==="empty");
  liveView.classList.toggle("active",which==="live");
  completeView.classList.toggle("active",which==="complete");
}

function buildPool(mode){
  var deck=activeDeck();if(!deck)return[];
  if(mode==="focus"){
    return deck.cards.filter(function(c){return deck.progress[c.id]!=="known";}).map(function(c){return c.id;});
  } else if(mode==="mixed"){
    var unknown=deck.cards.filter(function(c){return deck.progress[c.id]!=="known";});
    var known=deck.cards.filter(function(c){return deck.progress[c.id]==="known";});
    var take=Math.min(known.length,Math.max(2,Math.round(unknown.length*0.25)));
    var knownSample=shuffle(known.map(function(c){return c.id;})).slice(0,take);
    return unknown.map(function(c){return c.id;}).concat(knownSample);
  } else { /* all */
    return deck.cards.map(function(c){return c.id;});
  }
}

function setModeBtns(mode){
  el("modeAll").classList.toggle("active",mode==="all");
  el("modeFocus").classList.toggle("active",mode==="focus");
  el("modeMixed").classList.toggle("active",mode==="mixed");
}

function startSession(mode,overrideIds){
  var deck=activeDeck();if(!deck){showSubview("empty");return;}
  session.mode=mode||"all";
  session.results={};
  session.startTime=Date.now();
  session.reviseIds=null;
  flipped=false;
  if(overrideIds){
    session.order=shuffle(overrideIds);
  } else {
    var pool=buildPool(session.mode);
    session.order=shuffle(pool);
  }
  session.pos=0;
  marking=false;
  setModeBtns(session.mode);
  renderProgress();
  renderCard();
}

function renderProgress(){
  var deck=activeDeck();if(!deck)return;
  var total=session.order.length;
  var knownN=Object.keys(session.results).filter(function(id){return session.results[id]==="known";}).length;
  var unknownN=Object.keys(session.results).filter(function(id){return session.results[id]==="unknown";}).length;
  var seenN=knownN+unknownN;
  el("scoreKnown").textContent="✓ "+knownN;
  el("scoreUnknown").textContent="✗ "+unknownN;
  el("progressRight").textContent=seenN+" / "+total;
  var knownPct=total?Math.round(knownN/total*100):0;
  var unknownPct=total?Math.round(unknownN/total*100):0;
  el("progressKnown").style.width=knownPct+"%";
  el("progressUnknown").style.left=knownPct+"%";
  el("progressUnknown").style.width=unknownPct+"%";
}

function currentCard(){
  var deck=activeDeck();if(!deck||session.pos>=session.order.length)return null;
  var id=session.order[session.pos];
  return deck.cards.find(function(c){return c.id===id;})||null;
}

function saveSessionToHistory(){
  var deck=activeDeck();if(!deck)return;
  var knownN=Object.keys(session.results).filter(function(id){return session.results[id]==="known";}).length;
  var unknownN=Object.keys(session.results).filter(function(id){return session.results[id]==="unknown";}).length;
  var seen=knownN+unknownN;
  if(seen===0)return; /* don't save empty sessions */
  var pct=seen>0?Math.round(knownN/seen*100):0;
  if(!library.history)library.history=[];
  library.history.push({
    id:Date.now(),deckId:deck.id,deckName:deck.name,mode:session.mode,
    total:session.order.length,seen:seen,known:knownN,unknown:unknownN,pct:pct,ts:Date.now()
  });
  /* keep last 200 history entries total */
  if(library.history.length>200)library.history=library.history.slice(-200);
  scheduleSave();
}

function renderCard(){
  var card=currentCard();
  flipped=false;
  cardEl.classList.remove("flipped");
  stampEl.classList.remove("show","know","dontknow");
  stampTextEl.textContent="";

  if(!card){
    saveSessionToHistory();
    /* populate complete screen */
    var knownN=Object.keys(session.results).filter(function(id){return session.results[id]==="known";}).length;
    var unknownN=Object.keys(session.results).filter(function(id){return session.results[id]==="unknown";}).length;
    var seen=knownN+unknownN;
    var pct=seen>0?Math.round(knownN/seen*100):0;
    el("completeTitle").textContent=session.order.length===0?"Nothing to study here":"Session complete";
    el("completeKnown").textContent=knownN;
    el("completeUnknown").textContent=unknownN;
    el("completePct").textContent=seen>0?pct+"%":"—";
    el("sessionBarKnown").style.width=seen>0?Math.round(knownN/seen*100)+"%":"0%";
    el("sessionBarUnknown").style.width=seen>0?Math.round(unknownN/seen*100)+"%":"0%";
    /* revise button */
    var wrongIds=Object.keys(session.results).filter(function(id){return session.results[id]==="unknown";}).map(Number);
    el("reviseBtn").hidden=wrongIds.length===0;
    session.reviseIds=wrongIds;
    /* default next mode: focus if there are unknowns, else all */
    var defaultNext=unknownN>0?"focus":"all";
    setNextModeBtns(defaultNext);
    showSubview("complete");
    return;
  }
  showSubview("live");
  frontText.textContent=card.front;
  backText.textContent=card.back;
}

/* next-session mode in complete screen */
function setNextModeBtns(mode){
  nextMode=mode;
  el("nextAll").classList.toggle("active",mode==="all");
  el("nextFocus").classList.toggle("active",mode==="focus");
  el("nextMixed").classList.toggle("active",mode==="mixed");
}
el("nextAll").addEventListener("click",function(){setNextModeBtns("all");});
el("nextFocus").addEventListener("click",function(){setNextModeBtns("focus");});
el("nextMixed").addEventListener("click",function(){setNextModeBtns("mixed");});

el("studyAgainBtn").addEventListener("click",function(){startSession(nextMode);});
el("reviseBtn").addEventListener("click",function(){
  if(session.reviseIds&&session.reviseIds.length>0)startSession("focus",session.reviseIds);
});

function flipCard(){if(!currentCard())return;flipped=!flipped;cardEl.classList.toggle("flipped",flipped);}

function showStamp(status){
  stampEl.classList.remove("show","know","dontknow");
  stampTextEl.textContent=status==="known"?"合格":"復習";
  stampEl.classList.add(status==="known"?"know":"dontknow");
  void stampEl.offsetWidth;
  stampEl.classList.add("show");
}

function markCard(status){
  if(marking)return;
  var card=currentCard(),deck=activeDeck();
  if(!card||!deck)return;
  marking=true;
  /* record to session results */
  session.results[card.id]=status;
  /* update cumulative deck progress */
  deck.progress[card.id]=status;
  scheduleSave();
  renderProgress();
  var stampAndAdvance=function(){showStamp(status);setTimeout(advance,650);};
  if(!flipped){flipped=true;cardEl.classList.add("flipped");setTimeout(stampAndAdvance,370);}
  else{stampAndAdvance();}
}
function advance(){marking=false;session.pos++;renderCard();}

cardEl.addEventListener("click",flipCard);
el("btnKnow").addEventListener("click",function(e){e.stopPropagation();markCard("known");});
el("btnDontKnow").addEventListener("click",function(e){e.stopPropagation();markCard("unknown");});
el("skipBtn").addEventListener("click",function(e){e.stopPropagation();advance();});
el("modeAll").addEventListener("click",function(){if(session.mode!=="all")startSession("all");});
el("modeFocus").addEventListener("click",function(){if(session.mode!=="focus")startSession("focus");});
el("modeMixed").addEventListener("click",function(){if(session.mode!=="mixed")startSession("mixed");});

document.addEventListener("keydown",function(e){
  if(currentScreen!=="study")return;
  if(document.activeElement&&(document.activeElement.tagName==="TEXTAREA"||document.activeElement.tagName==="INPUT"))return;
  if(!liveView.classList.contains("active"))return;
  if(e.code==="Space"||e.code==="Enter"){e.preventDefault();flipCard();}
  else if(e.code==="ArrowRight"){e.preventDefault();markCard("known");}
  else if(e.code==="ArrowLeft"){e.preventDefault();markCard("unknown");}
});

function renderStudy(){
  updateDeckPill();
  if(!activeDeck()){showSubview("empty");return;}
  startSession("all");
}

/* ================= history screen ================= */
function deckHistory(){
  var deck=activeDeck();if(!deck||!library.history)return[];
  return library.history.filter(function(h){return h.deckId===deck.id;});
}

function renderHistory(){
  var deck=activeDeck();
  var hist=deckHistory();
  var container=el("historyContent");
  container.innerHTML="";

  if(!deck){container.innerHTML='<p class="noHistHint">Select a deck first to see its history.</p>';return;}
  if(hist.length===0){container.innerHTML='<p class="noHistHint">No sessions recorded for this deck yet. Complete a session to see history here.</p>';return;}

  /* all-time stats */
  var totalSessions=hist.length;
  var totalSeen=hist.reduce(function(s,h){return s+h.seen;},0);
  var avgPct=Math.round(hist.reduce(function(s,h){return s+h.pct;},0)/hist.length);
  var statsDiv=document.createElement("div");
  statsDiv.className="histStats";
  statsDiv.innerHTML=[
    '<div class="histStat"><div class="histStatN">'+totalSessions+'</div><div class="histStatL">Sessions</div></div>',
    '<div class="histStat"><div class="histStatN">'+totalSeen+'</div><div class="histStatL">Cards seen</div></div>',
    '<div class="histStat"><div class="histStatN">'+avgPct+'%</div><div class="histStatL">Avg score</div></div>'
  ].join("");
  container.appendChild(statsDiv);

  /* best session */
  var best=hist.slice().sort(function(a,b){
    if(b.pct!==a.pct)return b.pct-a.pct;
    return b.seen-a.seen; /* tie-break: more cards seen */
  })[0];
  var bestDiv=document.createElement("div");
  bestDiv.className="bestSessionCard";
  var bestKnPct=best.seen>0?Math.round(best.known/best.seen*100):0;
  var bestUnPct=best.seen>0?Math.round(best.unknown/best.seen*100):0;
  bestDiv.innerHTML='<div class="bestLabel">Best session</div>'+
    '<div class="bestRow"><span class="bestPct" style="color:'+pctColor(best.pct)+'">'+best.pct+'%</span>'+
    '<div class="bestMeta">'+best.known+' got it · '+best.unknown+" to review<br>"+fmtDate(best.ts)+' · '+best.mode+'</div></div>'+
    '<div class="bestBar"><div class="bestBarKnown" style="width:'+bestKnPct+'%"></div>'+
    '<div class="bestBarUnknown" style="width:'+bestUnPct+'%"></div></div>';
  container.appendChild(bestDiv);

  /* bubble chart */
  var bubblesSection=document.createElement("div");
  bubblesSection.className="bubblesSection";
  bubblesSection.innerHTML='<div class="bubblesLabel">All sessions</div>';
  var bubblesWrap=document.createElement("div");
  bubblesWrap.className="bubblesWrap";
  var recent=hist.slice(-40); /* last 40 */
  recent.forEach(function(h){
    var b=document.createElement("div");
    b.className="bubble"+(h===best?" best":"");
    b.style.background=pctColor(h.pct);
    b.textContent=h.pct+"%";
    b.title=fmtDate(h.ts)+"\n"+h.known+" got it · "+h.unknown+" to review · "+h.pct+"% · "+h.mode;
    bubblesWrap.appendChild(b);
  });
  bubblesSection.appendChild(bubblesWrap);
  container.appendChild(bubblesSection);

  /* session list */
  var listLabel=document.createElement("div");
  listLabel.className="bubblesLabel";
  listLabel.textContent="Recent sessions";
  container.appendChild(listLabel);
  var listDiv=document.createElement("div");
  listDiv.className="histList";
  var toShow=hist.slice().reverse().slice(0,20);
  toShow.forEach(function(h){
    var entry=document.createElement("div");
    entry.className="histEntry";
    var knPct=h.seen>0?Math.round(h.known/h.seen*100):0;
    var unPct=h.seen>0?Math.round(h.unknown/h.seen*100):0;
    entry.innerHTML=
      '<div class="histPctBadge" style="background:'+pctColor(h.pct)+'">'+h.pct+'%</div>'+
      '<div class="histMeta">'+
        '<div class="histDate">'+fmtDate(h.ts)+'</div>'+
        '<div class="histSub">'+h.known+' got it · '+h.unknown+' to review · '+h.seen+' cards · '+h.mode+'</div>'+
        '<div class="histBar"><div class="histBarKnown" style="width:'+knPct+'%"></div>'+
        '<div class="histBarUnknown" style="width:'+unPct+'%"></div></div>'+
      '</div>';
    listDiv.appendChild(entry);
  });
  container.appendChild(listDiv);
}

